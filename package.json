{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --plugin=prettier-plugin-astro --write .",
    "lint": "eslint --ext .astro src && prettier --plugin=prettier-plugin-astro --check \"**/*.{ts,tsx,scss,md,astro}\"",
    "prepare": "husky install",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "echo \"No tests at this time\" && exit 0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.5.10",
    "@astrojs/mdx": "^2.3.1",
    "@astrojs/svelte": "^5.7.3",
    "@iconify/json": "^2.2.444",
    "@typescript-eslint/parser": "^7.18.0",
    "@unocss/astro": "^0.58.9",
    "@unocss/preset-icons": "^0.58.9",
    "@unocss/preset-uno": "^0.58.9",
    "astro": "^4.16.19",
    "axe-core": "^4.11.1",
    "cypress": "^13.17.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^0.31.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.13.0",
    "rollup": "^4.59.0",
    "sass": "^1.97.3",
    "stylelint": "^16.26.1",
    "stylelint-config-sass-guidelines": "^11.1.0",
    "stylelint-order": "^6.0.4",
    "svelte": "^4.2.20",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "lint-staged": {
    "*.astro": [
      "eslint --cache --fix"
    ],
    "*.scss": "stylelint --fix",
    "*.{ts,tsx,scss,md,astro}": "prettier --plugin=prettier-plugin-astro --write"
  },
  "packageManager": "pnpm@8.15.0"
}
