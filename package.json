{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --plugin=prettier-plugin-astro --write .",
    "lint": "eslint . src && prettier --plugin=prettier-plugin-astro --check \"**/*.{ts,tsx,scss,md,astro}\"",
    "prepare": "husky",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "echo \"No tests at this time\" && exit 0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/svelte": "^7.2.5",
    "@iconify/json": "^2.2.444",
    "@typescript-eslint/parser": "^8.56.1",
    "@unocss/astro": "^66.6.2",
    "@unocss/preset-icons": "^66.6.2",
    "astro": "^5.18.0",
    "axe-core": "^4.11.1",
    "cypress": "^15.11.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rollup": "^4.59.0",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-order": "^7.0.1",
    "svelte": "^5.53.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.astro": [
      "eslint --cache --fix",
      "prettier --plugin=prettier-plugin-astro --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --plugin=prettier-plugin-astro --write"
    ],
    "*.{ts,tsx,md}": [
      "prettier --plugin=prettier-plugin-astro --write"
    ]
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "typescript-eslint": "^8.56.1"
  }
}
