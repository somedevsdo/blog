{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --plugin=prettier-plugin-astro --write .",
    "lint": "eslint . src && stylelint \"src/**/*.{astro,css,scss}\" && prettier --plugin=prettier-plugin-astro --check \"**/*.{ts,tsx,css,scss,md,astro}\"",
    "prepare": "husky",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@axe-core/playwright": "^4.11.0",
    "@iconify-json/bi": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.40",
    "@iconify-json/teenyicons": "^1.2.2",
    "@playwright/test": "^1.55.1",
    "@somedevsdo/tailwind": "latest",
    "@tailwindcss/vite": "^4.1.13",
    "@typescript-eslint/parser": "^8.56.1",
    "astro": "^5.18.0",
    "astro-icon": "^1.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rollup": "^4.59.0",
    "stylelint": "^16.24.0",
    "stylelint-config-astro": "^1.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^6.12.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.astro": [
      "eslint --cache --fix",
      "prettier --plugin=prettier-plugin-astro --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --plugin=prettier-plugin-astro --write"
    ],
    "*.{ts,tsx,md}": [
      "prettier --plugin=prettier-plugin-astro --write"
    ]
  },
  "packageManager": "pnpm@8.15.0"
}
