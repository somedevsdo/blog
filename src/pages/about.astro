---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="mx-auto my-16 max-w-3xl px-6 text-clr-text md:my-24">
    <section
      class="rounded-xl bg-clr-content-background p-8 shadow-[0_1.25rem_1.875rem_rgba(0,0,0,0.15)]"
    >
      <h1
        class="font-header m-0 text-[2.25rem] leading-[var(--line-height-header)] font-bold text-clr-header"
      >
        About us
      </h1>
      <p class="mb-0 mt-4 text-base leading-[var(--line-height-text)]">
        Rag tag band of misfits ready to blog stuff up.
      </p>
    </section>

    <div class="mt-6 text-sm font-bold">
      <a class="no-underline hover:underline" href="/">← Back to home</a>
    </div>
  </main>
</Layout>
