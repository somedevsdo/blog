---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import { getAuthorData } from "../../lib/author";
import getDateFormatted from "../../lib/date";

export async function getStaticPaths() {
  const blogEntries = await getCollection("post");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const externalEncodedPath: string = `https://somedevsdo.com${Astro.url.pathname}`;

const { entry } = Astro.props;
const { Content } = await entry.render();

const author = getAuthorData(entry.data.author);
const transitionSlug = entry.slug.replaceAll("/", "-");
---

<Layout title={entry.data.title}>
  <div
    class="absolute h-70 w-full bg-[linear-gradient(278.59deg,#c291e1_1.21%,#5b0a91_92.25%)] [clip-path:polygon(0_0,100%_0,100%_96%,0_100%)] dark:bg-[linear-gradient(278.59deg,#520483_1.21%,#12001e_92.25%)] md:h-100 lg:h-120"
  >
  </div>
  <div class="relative mx-4 w-auto wrap-break-word md:mx-auto md:max-w-176 lg:max-w-210">
    <header>
      <a
        class="my-4 mt-8 block text-sm leading-(--line-height-text) font-bold text-white no-underline hover:underline md:mb-8 md:mt-14 lg:mt-16"
        href="/"
      >
        ← All posts
      </a>
      <div
        class="relative mx-auto h-60 overflow-hidden rounded-2.5 bg-primary-background md:h-95 lg:h-110"
      >
        <Image
          transition:name={`post-image-${transitionSlug}`}
          class="h-full w-full object-cover"
          alt="Featured image"
          src={import(
            `../../images/posts/featured/${entry.data.featuredImage.replace(".jpg", "")}.jpg`
          )}
          height={640}
          width={860}
        />
        <div
          transition:name={`post-image-dim-${transitionSlug}`}
          class="pointer-events-none absolute inset-0 bg-transparent transition dark:bg-black/40"
        >
        </div>
      </div>
    </header>
    <main class="mx-auto my-6 mb-24 rounded-2.5 bg-content-background p-6 md:px-10 md:py-8">
      <div class="md:flex md:items-center md:justify-between">
        <ul
          class="mb-4 flex list-none justify-center gap-4 border-b border-primary-background p-0 pb-2 md:order-2 md:mb-0 md:border-0 md:pb-0"
        >
          <li class="mb-0 md:leading-none">
            <a
              class="inline-block cursor-pointer bg-transparent text-link"
              href={`https://x.com/intent/post?url=${externalEncodedPath}&text=${encodeURIComponent(
                entry.data.title
              )}&via=somedevsdo`}
              title="Share post on X"
            >
              <Icon class="h-5 w-5" name="simple-icons:x" aria-hidden="true" />
            </a>
          </li>
          <li class="mb-0 md:leading-none">
            <button
              class="inline-block cursor-pointer bg-transparent text-link"
              title="Copy post link to clipboard"
              type="button"
              id="copy-button"
            >
              <Icon class="h-5 w-5" name="bi:link-45deg" aria-hidden="true" />
            </button>
          </li>
        </ul>

        <div class="mb-8 md:order-1 md:mb-0">
          <span
            transition:name={`post-category-${transitionSlug}`}
            class="font-header text-base font-bold capitalize"
            >{entry.data.category}<span class="px-3">&middot;</span></span
          >
          <span
            transition:name={`post-date-${transitionSlug}`}
            class="text-base leading-(--line-height-text)"
            >{getDateFormatted(entry.data.date.toString())}</span
          >
        </div>
      </div>

      <h1
        transition:name={`post-title-${transitionSlug}`}
        class="font-header mt-6 mb-4 text-[2.25rem] leading-(--line-height-header) font-bold text-header md:mb-6 md:mt-8 md:text-[2.75rem]"
      >
        {entry.data.title}
      </h1>
      <div class="mb-10 text-base leading-(--line-height-text)">
        By{" "}
        <a class="underline" href={`/author/${author.id}`}>
          {author.name}
        </a>
      </div>
      <article
        class="text-base leading-(--line-height-text) text-primary-text [&_a]:underline [&_blockquote]:mb-10 [&_blockquote]:border-l-[0.4rem] [&_blockquote]:border-l-foreground [&_blockquote]:px-4 [&_blockquote]:py-3 [&_blockquote]:italic [&_h2]:mb-2 [&_h2]:font-header [&_h2]:text-[1.75rem] [&_h2]:leading-(--line-height-header) [&_h2]:font-bold [&_h2]:text-header [&_h3]:mb-2 [&_h3]:font-header [&_h3]:text-[1.375rem] [&_h3]:leading-(--line-height-header) [&_h3]:font-bold [&_h3]:text-header [&_h4]:mb-2 [&_h4]:font-header [&_h4]:text-[1.125rem] [&_h4]:leading-(--line-height-header) [&_h4]:font-bold [&_h4]:text-header [&_img]:w-full [&_img]:transition [&_img]:dark:brightness-75 [&_li]:mb-2 [&_p:last-child]:mb-0 [&_p]:mb-10 [&_pre]:mt-0 [&_pre]:mb-10 [&_pre]:rounded [&_pre]:text-base [&_ul_ul]:mb-0 [&_ul]:mb-10"
      >
        <Content />
      </article>
      <div>
        {
          entry.data.canonical && (
            <p>
              <em>
                Originally published at{" "}
                <a class="underline" href={entry.data.canonical}>
                  {new URL(entry.data.canonical).hostname}
                </a>
              </em>
            </p>
          )
        }
      </div>
    </main>
  </div>
</Layout>

<script is:inline define:vars={{ externalEncodedPath }}>
  document
    .getElementById("copy-button")
    ?.addEventListener("click", () => navigator.clipboard.writeText(externalEncodedPath));
</script>
