---
import { Image } from "astro:assets";

export type Props = {
  size?: string;
  src: string;
};

const { size = "large", src } = Astro.props as Props;
let avatarSize: number;

switch (size) {
  case "x-small":
    avatarSize = 40;
    break;
  case "small":
    avatarSize = 52;
    break;
  case "medium":
    avatarSize = 77;
    break;
  case "x-large":
    avatarSize = 180;
    break;
  case "large":
  default:
    avatarSize = 120;
    break;
}
---

<span
  class="relative inline-block overflow-hidden rounded-full"
  style={`height: ${avatarSize}px; width: ${avatarSize}px;`}
>
  <Image
    class="h-full w-full rounded-full object-cover"
    alt=""
    src={src}
    height={avatarSize}
    width={avatarSize}
  />
</span>
