---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-button"
  class="cursor-pointer rounded bg-transparent p-(--size-padding-x-small) text-white"
  title="Toggle dark mode"
  aria-label="Toggle dark mode"
  type="button"
>
  <Icon class="hidden h-6 w-6 dark:block" name="bi:moon-stars-fill" aria-hidden="true" />
  <Icon class="h-6 w-6 dark:hidden" name="bi:sun-fill" aria-hidden="true" />
</button>

<script>
  const darkModeQuery = window.matchMedia("(prefers-color-scheme: dark)");

  const getTheme = () => {
    const defaultTheme = darkModeQuery.matches ? "dark" : "light";
    const localTheme = localStorage.getItem("theme");
    return localTheme === "dark" || localTheme === "light" ? localTheme : defaultTheme;
  };

  const applyTheme = () => {
    const theme = getTheme();
    document.documentElement.setAttribute("data-theme", theme);
    document.documentElement.style.setProperty("color-scheme", theme);

    const button = document.getElementById("theme-button");
    if (button) {
      const title = theme === "dark" ? "Toggle light mode" : "Toggle dark mode";
      button.setAttribute("title", title);
      button.setAttribute("aria-label", title);
    }
  };

  const toggleTheme = () => {
    const nextTheme = getTheme() === "light" ? "dark" : "light";
    localStorage.setItem("theme", nextTheme);
    applyTheme();
  };

  applyTheme();
  darkModeQuery.addEventListener("change", (event) => {
    const nextTheme = event.matches ? "dark" : "light";
    localStorage.setItem("theme", nextTheme);
    applyTheme();
  });

  const button = document.getElementById("theme-button");
  button?.addEventListener("click", toggleTheme);
</script>
